{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api|assets|favicon.ico|.*\\.svg|.*\\.png|.*\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
